#!/usr/bin/env python3
import logging
import os
import socket
import subprocess

SOCKET_PATH = os.path.join(os.environ["SNAP"], "consul", "shutdown.sock")


def shutdown_vms():
    logging.info("Initiating shutdown of all running VMs...")
    try:
        result = subprocess.run(
            ["virsh", "list", "--name"],
            check=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True
        )
        vm_names = result.stdout.strip().splitlines()

        for vm in vm_names:
            if vm.strip():
                logging.info(f"Shutting down VM: {vm}")
                subprocess.run(["virsh", "shutdown", vm.strip()], check=True)
        logging.info("Shutdown commands sent.")
    except Exception as e:
        logging.error(f"VM shutdown error: {str(e)}")


def run_listener():
    logging.basicConfig(level=logging.INFO)

    if os.path.exists(SOCKET_PATH):
        os.remove(SOCKET_PATH)

    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as server_sock:
        server_sock.bind(SOCKET_PATH)
        os.chmod(SOCKET_PATH, 0o666)
        server_sock.listen()
        logging.info(f"Listening on Unix socket: {SOCKET_PATH}")

        while True:
            conn, _ = server_sock.accept()
            with conn:
                data = conn.recv(1024)
                if not data:
                    continue
                command = data.decode().strip()
                logging.info(f"Received command: {command}")
                if command.lower() == "shutdown":
                    shutdown_vms()
                    conn.sendall(b"Shutdown initiated")
                else:
                    conn.sendall(b"Unknown command")


if __name__ == "__main__":
    run_listener()
